# Microsoft Foundry project endpoint
# Format:
# https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>

# Chat model deployment created inside the Foundry project
FOUNDRY_MODEL_DEPLOYMENT=gpt-4.1

# Embedding model deployment created inside the Foundry project
FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Application metadata
APP_NAME=azure-ai-foundry-langgraph-agents
APP_ENVIRONMENT=local
APP_VERSION=0.1.0

# Generation defaults
MODEL_MAX_OUTPUT_TOKENS=800
SYSTEM_PROMPT=You are a concise enterprise AI assistant.

# Router configuration
ROUTER_MAX_OUTPUT_TOKENS=16
ROUTER_PROMPT=Classify the request as 'time' if it asks for the current time or UTC time; otherwise classify it as 'general'. Return only the route name.

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<search-service-name>.search.windows.net
AZURE_SEARCH_INDEX_NAME=supply-chain-docs
AZURE_SEARCH_ADMIN_KEY=<your-search-admin-key>
AZURE_SEARCH_TOP_K=3
AZURE_SEARCH_VECTOR_FIELD=content_vector
AZURE_SEARCH_VECTOR_DIMENSIONS=1536